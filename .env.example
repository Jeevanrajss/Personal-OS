# Copy to .env and fill in.
# ---------------------------------------------------------------------
# APP
# ---------------------------------------------------------------------
APP_NAME=Personal OS
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
TIMEZONE=Asia/Kolkata
CURRENCY=INR

# ---------------------------------------------------------------------
# DATABASE
# DB_ENCRYPTION=false  →  plain SQLite, works everywhere (default, recommended for most users)
# DB_ENCRYPTION=true   →  SQLCipher encryption; requires: pip install sqlcipher3
#                          On Mac: brew install sqlcipher first
#                          On Linux: sudo apt install libsqlcipher-dev first
#                          NOT supported on Windows — keep false on Windows
# If you enable encryption, use a strong passphrase and store it safely.
# If you lose it, your data is unrecoverable.
# ---------------------------------------------------------------------
DB_ENCRYPTION=false
DB_PASSPHRASE=replace-with-a-strong-passphrase
# DB_PATH defaults to ./data/personal-os.db (leave unset unless moving it)

# ---------------------------------------------------------------------
# LLM — LM Studio by default.
# Any OpenAI-compatible server works (Ollama /v1, llama.cpp, vLLM, OpenAI).
#
# For LM Studio:
#   1. Open LM Studio -> Developer tab -> Start Server.
#   2. Load your Gemma 4 E4B model (or whichever chat model you prefer).
#   3. Make sure nomic-embed-text-v1.5-GGUF is downloaded.
#   4. Enable "Just-in-Time Model Loading" in Settings.
#   5. Use the model IDs exactly as LM Studio shows them in `/v1/models`.
#
# For Windows -> Mac over LAN:
#   On Mac LM Studio: turn on "Serve on local network".
#   Set LLM_HOST here to http://<mac-ip>:1234
# ---------------------------------------------------------------------
LLM_PROVIDER=lmstudio
LLM_HOST=http://127.0.0.1:1234
LLM_CHAT_MODEL=google/gemma-4-e4b
LLM_FAST_MODEL=google/gemma-4-e4b
LLM_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5-gguf

# ---------------------------------------------------------------------
# PRIVACY
# ---------------------------------------------------------------------
OFFLINE_MODE=false
