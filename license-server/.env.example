# Admin bearer token — set this to a long random string, keep it secret
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=change-me-to-a-long-random-string

# SQLite database file path (relative to license-server/ dir)
DATABASE_URL=sqlite:///./license.db

# App name shown in admin UI
APP_NAME=Personal OS
